{
  "config": "scripts/train_sardet_config.example.json",
  "data_root": "src/data/SARDet_COCO",
  "train_ann": "src/data/SARDet_COCO/annotations/train.json",
  "val_ann": "src/data/SARDet_COCO/annotations/val.json",
  "images_root": "src/data/SARDet_COCO/images",
  "summit_checkpoint": "/home/georg/Documents/ESA/ClearSAR/checkpoints/summit/checkpoint.pth",
  "backbone_variant": "auto",
  "output_dir": "outputs/sardet",
  "image_size": 128,
  "batch_size": 1,
  "num_workers": 0,
  "phase_a_epochs": 1,
  "phase_b_epochs": 0,
  "optimizer": "kl_shampoo",
  "lr": 0.0001,
  "backbone_lr_mult": 0.1,
  "weight_decay": 0.0001,
  "grad_clip_norm": 0.1,
  "soap_betas": [
    0.9,
    0.95
  ],
  "soap_shampoo_beta": 0.95,
  "soap_eps": 1e-08,
  "soap_weight_decay_method": "decoupled",
  "soap_nesterov": false,
  "soap_precondition_frequency": 1,
  "soap_adam_warmup_steps": 0,
  "soap_correct_bias": false,
  "soap_fp32_matmul_prec": "high",
  "soap_use_eigh": false,
  "soap_qr_fp32_matmul_prec": "high",
  "soap_use_adaptive_criteria": false,
  "soap_adaptive_update_tolerance": 1e-07,
  "soap_power_iter_steps": 1,
  "soap_max_update_rms": 0.0,
  "soap_no_kl_shampoo": false,
  "soap_correct_shampoo_beta_bias": "none",
  "num_classes": 6,
  "num_queries": 300,
  "hidden_dim": 256,
  "num_feature_levels": 4,
  "nheads": 8,
  "num_encoder_layers": 6,
  "num_decoder_layers": 6,
  "dim_feedforward": 1024,
  "dropout": 0.1,
  "enc_n_points": 4,
  "dec_n_points": 4,
  "no_two_stage": false,
  "no_box_refine": false,
  "include_no_object": true,
  "cls_loss_coef": 1.0,
  "bbox_loss_coef": 5.0,
  "giou_loss_coef": 2.0,
  "eos_coef": 0.1,
  "seed": 42,
  "device": "cuda",
  "print_freq": 20
}